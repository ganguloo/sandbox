DIM = 6

VALID
1 0 1 1 0 1 

INEQUALITIES_SECTION
(  1)    -x2-x3          <= -1
(  2)          -x4       <=  0
(  3)             -x5    <=  0
(  4)                -x6 <=  0
(  5) -x1   +x3          <=  0
(  6)    -x2   +x4-x5-x6 <=  0
(  7)                +x6 <=  1
(  8)             +x5    <=  1
(  9)          +x4       <=  1
( 10)    +x2             <=  1
( 11) +x1                <=  1

END
