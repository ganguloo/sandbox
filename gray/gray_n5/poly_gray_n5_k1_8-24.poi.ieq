DIM = 5

VALID
1 0 1 0 0 

INEQUALITIES_SECTION
(  1) -x1-x2          <= -1
(  2)    -x2-x3       <= -1
(  3)          -x4    <=  0
(  4)             -x5 <=  0
(  5)    -x2      +x5 <=  0
(  6)    -x2   +x4    <=  0
(  7)       +x3       <=  1
(  8)    +x2          <=  1
(  9) +x1             <=  1

END
