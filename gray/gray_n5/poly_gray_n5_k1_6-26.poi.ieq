DIM = 5

VALID
1 0 1 1 1 

INEQUALITIES_SECTION
(  1)    -x2-x3       <= -1
(  2) -x1             <=  0
(  3)          -x4    <=  0
(  4)             -x5 <=  0
(  5) -x1-x2   +x4    <=  0
(  6)    -x2   +x4-x5 <=  0
(  7)             +x5 <=  1
(  8)          +x4    <=  1
(  9)       +x3       <=  1
( 10)    +x2          <=  1
( 11) +x1             <=  1

END
